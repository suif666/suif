-- Base64 解码（优先使用执行器自带，失败则用纯 Lua 实现）
local function base64decode(data)
    if crypt and crypt.base64decode then
        return crypt.base64decode(data)
    end

    -- 纯 Lua Base64 解码（兼容性兜底）
    local b = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
    data = string.gsub(data, '[^'..b..'=]', '')
    return (data:gsub('.', function(x)
        if x == '=' then return '' end
        local r, f = '', (b:find(x) - 1)
        for i = 6, 1, -1 do
            r = r .. (f % 2^i - f % 2^(i-1) > 0 and '1' or '0')
        end
        return r
    end):gsub('%d%d%d?%d?%d?%d?%d?%d?', function(x)
        if #x \~= 8 then return '' end
        local c = 0
        for i = 1, 8 do
            c = c + (x:sub(i, i) == '1' and 2^(8 - i) or 0)
        end
        return string.char(c)
    end))
end

-- 主加载逻辑
local url = "https://suture-hub-loader.sfbdsl666.workers.dev"
local reqFunc = (syn and syn.request) or (http and http.request) or request

if not reqFunc then
    showError("加载失败", "当前执行器不支持网络请求，请更换执行器。")
    return
end

local success, response = pcall(function()
    return reqFunc({
        Url = url,
        Method = "GET",
        Headers = {
            ["X-Suture-Loader"] = "1"  -- 关键：必须带这个 Header
        }
    })
end)

if not success or not response then
    showError("网络错误", "无法连接到云端服务器，请检查网络或加速器。")
    return
end

local code = response.StatusCode or response.status
local body = response.Body or response.body

if code \~= 200 or not body or body == "" then
    showError("加载失败", "云端返回异常（状态码: " .. tostring(code) .. "）\n可能是服务器维护中。")
    return
end

-- 解码 Base64
local decoded
local decodeSuccess, decodeResult = pcall(function()
    return base64decode(body)
end)

if not decodeSuccess or not decodeResult or decodeResult == "" then
    showError("解码失败", "脚本解码失败，请联系作者。")
    return
end

decoded = decodeResult

-- 执行主脚本
local loadSuccess, loadErr = pcall(function()
    local fn, err = loadstring(decoded)
    if not fn then
        error(err or "loadstring 失败")
    end
    fn()
end)

if not loadSuccess then
    showError("运行崩溃", "主脚本执行出错：\n\n" .. tostring(loadErr))
end
