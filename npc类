if getgenv().__NPC_REMOTE_LOADED then
    return
end
getgenv().__NPC_REMOTE_LOADED = true

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local CoreGui = game:GetService("CoreGui")

local NPCSettings = {
    EnableHighlight = false,
    MaxHighlightDistance = 150,
    ShowHealthDisplay = true,
    EnableNPCEnlarge = false,
    NPCSizeMultiplier = 4,
    EnlargePartMode = "全部"
}

local stored = setmetatable({}, { __mode = "k" })
local activeNPCs = {}
local npcs = {}
local connections = {}
local uiBuilt = false

local enlargeTargets = {
    ["头部"] = {"Head"},
    ["身体"] = {"HumanoidRootPart"},
    ["躯干"] = {"UpperTorso", "LowerTorso", "Torso"},
    ["全部"] = {"Head", "HumanoidRootPart", "UpperTorso", "LowerTorso", "Torso"}
}

local function safeDisconnectAll()
    for _, c in ipairs(connections) do
        pcall(function()
            c:Disconnect()
        end)
    end
    connections = {}
end

local function restoreAllNPCs()
    for part, orig in pairs(stored) do
        if part and part.Parent then
            pcall(function()
                part.Size = orig.Size
                part.Transparency = orig.Transparency
                part.CanCollide = orig.CanCollide
            end)
        end
    end
end

local function destroyAllUiArtifacts()
    local folder = CoreGui:FindFirstChild("NPC_REMOTE_FOLDER")
    if folder then
        folder:Destroy()
    end
end

local function cleanup()
    safeDisconnectAll()
    restoreAllNPCs()
    destroyAllUiArtifacts()
    stored = setmetatable({}, { __mode = "k" })
    activeNPCs = {}
    npcs = {}
    uiBuilt = false
end

local old = rawget(getgenv(), "__NPC_REMOTE_STATE")
if old and type(old) == "table" and old.cleanup then
    pcall(old.cleanup)
end

getgenv().__NPC_REMOTE_STATE = {
    cleanup = cleanup
}

local function waitForNpcTab(timeout)
    timeout = timeout or 20
    local start = tick()
    repeat
        local Tabs = getgenv().Tabs
        if Tabs and Tabs.npcTab then
            return Tabs.npcTab
        end
        task.wait(0.1)
    until tick() - start > timeout
    return nil
end

local tab = waitForNpcTab(20)
if not tab then
    return
end

local function getPlayerPosition()
    local char = LocalPlayer.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
        if hrp then
            return hrp.Position
        end
    end
    local cam = workspace.CurrentCamera
    if cam then
        return cam.CFrame.Position
    end
    return Vector3.new()
end

local function getOrCreateBillboard(character, humanoid)
    local billboard = character:FindFirstChild("NPCHealthDisplay")
    if billboard then
        return billboard
    end

    billboard = Instance.new("BillboardGui")
    billboard.Name = "NPCHealthDisplay"
    billboard.Size = UDim2.new(4, 0, 1.5, 0)
    billboard.StudsOffset = Vector3.new(0, 2.5, 0)
    billboard.AlwaysOnTop = true
    billboard.Enabled = false

    local head = character:FindFirstChild("Head") or character.PrimaryPart or character:FindFirstChildWhichIsA("BasePart")
    billboard.Adornee = head

    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = "HP: " .. tostring(math.floor(humanoid.Health))
    textLabel.Font = Enum.Font.SourceSansBold
    textLabel.TextSize = 18
    textLabel.TextColor3 = Color3.new(1, 1, 1)
    textLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
    textLabel.TextStrokeTransparency = 0.25
    textLabel.Parent = billboard

    billboard.Parent = character

    if not humanoid:GetAttribute("HealthConnected") then
        humanoid:GetPropertyChangedSignal("Health"):Connect(function()
            local gui = character:FindFirstChild("NPCHealthDisplay")
            if gui then
                local label = gui:FindFirstChildOfClass("TextLabel")
                if label then
                    label.Text = "HP: " .. tostring(math.floor(humanoid.Health))
                end
            end
        end)
        humanoid:SetAttribute("HealthConnected", true)
    end

    return billboard
end

local function updateNPCVisibility(humanoid)
    if not humanoid or not humanoid.Parent then
        return
    end

    local character = humanoid.Parent
    if not character or Players:GetPlayerFromCharacter(character) then
        return
    end

    local playerPos = getPlayerPosition()
    local ok, npcPos = pcall(function()
        return character:GetPivot().Position
    end)
    if not ok then
        return
    end

    local distance = (npcPos - playerPos).Magnitude
    local withinRange = distance <= NPCSettings.MaxHighlightDistance

    local highlight = character:FindFirstChildOfClass("Highlight")
    if NPCSettings.EnableHighlight and withinRange then
        if not highlight then
            highlight = Instance.new("Highlight")
            highlight.FillTransparency = 1
            highlight.OutlineTransparency = 0
            highlight.Parent = character
        end
        highlight.Enabled = true
    elseif highlight then
        highlight.Enabled = false
    end

    local billboard = character:FindFirstChild("NPCHealthDisplay")
    if NPCSettings.ShowHealthDisplay and withinRange then
        billboard = billboard or getOrCreateBillboard(character, humanoid)
        if billboard then
            billboard.Enabled = true
        end
    elseif billboard then
        billboard.Enabled = false
    end
end

local function getTargetParts(obj)
    local list = enlargeTargets[NPCSettings.EnlargePartMode] or enlargeTargets["全部"]
    local result = {}

    for _, name in ipairs(list) do
        local p = obj:FindFirstChild(name)
        if p and p:IsA("BasePart") then
            table.insert(result, p)
        end
    end

    return result
end

local function enlargeNPC(obj)
    if not NPCSettings.EnableNPCEnlarge or not obj or not obj.Parent then
        return
    end

    local hum = obj:FindFirstChildOfClass("Humanoid") or obj:FindFirstChild("AnimationController")
    if not hum then
        return
    end

    for _, p in ipairs(getTargetParts(obj)) do
        if not stored[p] then
            stored[p] = {
                Size = p.Size,
                Transparency = p.Transparency,
                CanCollide = p.CanCollide
            }
        end

        p.Size = stored[p].Size * NPCSettings.NPCSizeMultiplier
        p.Transparency = 0.25
        p.CanCollide = false
    end
end

local function reEnlargeAllNPCs()
    for model in pairs(activeNPCs) do
        if model and model.Parent then
            enlargeNPC(model)
        end
    end
end

local function registerNPC(obj)
    if not obj or not obj:IsA("Model") then
        return
    end
    if Players:GetPlayerFromCharacter(obj) then
        return
    end

    local hum = obj:FindFirstChildOfClass("Humanoid") or obj:FindFirstChild("AnimationController")
    if not hum then
        return
    end

    if not activeNPCs[obj] then
        activeNPCs[obj] = true
        table.insert(npcs, hum)
    end

    if NPCSettings.EnableNPCEnlarge then
        enlargeNPC(obj)
    end
    updateNPCVisibility(hum)
end

for _, obj in ipairs(workspace:GetDescendants()) do
    registerNPC(obj)
end

connections[#connections + 1] = workspace.DescendantAdded:Connect(function(obj)
    task.defer(function()
        registerNPC(obj)
    end)
end)

connections[#connections + 1] = RunService.Heartbeat:Connect(function()
    for i = #npcs, 1, -1 do
        local hum = npcs[i]
        if not hum or not hum.Parent or Players:GetPlayerFromCharacter(hum.Parent) then
            table.remove(npcs, i)
        else
            updateNPCVisibility(hum)
        end
    end
end)

if not uiBuilt then
    uiBuilt = true

    local function safe(f)
        local ok, err = pcall(f)
        if not ok then
            warn("[NPC 功能] UI 创建失败: " .. tostring(err))
        end
    end

    safe(function()
        tab:Toggle({
            Title = "开启 NPC 高亮",
            Desc = "距离内显示高亮",
            Value = NPCSettings.EnableHighlight,
            Callback = function(v)
                NPCSettings.EnableHighlight = v
                for _, hum in ipairs(npcs) do
                    updateNPCVisibility(hum)
                end
            end
        })
    end)

    safe(function()
        tab:Slider({
            Title = "ESP 范围",
            Min = 0,
            Max = 500,
            Default = NPCSettings.MaxHighlightDistance,
            Callback = function(v)
                NPCSettings.MaxHighlightDistance = v
                for _, hum in ipairs(npcs) do
                    updateNPCVisibility(hum)
                end
            end
        })
    end)

    safe(function()
        tab:Toggle({
            Title = "显示 NPC 血量",
            Desc = "距离内显示血量",
            Value = NPCSettings.ShowHealthDisplay,
            Callback = function(v)
                NPCSettings.ShowHealthDisplay = v
                for _, model in pairs(activeNPCs) do
                    if model and model.Parent then
                        local gui = model:FindFirstChild("NPCHealthDisplay")
                        if gui then
                            gui.Enabled = v
                        end
                    end
                end
            end
        })
    end)

    safe(function()
        tab:Toggle({
            Title = "启用 NPC 增大",
            Desc = "放大 NPC 指定部位",
            Value = NPCSettings.EnableNPCEnlarge,
            Callback = function(v)
                NPCSettings.EnableNPCEnlarge = v
                restoreAllNPCs()
                if v then
                    reEnlargeAllNPCs()
                end
            end
        })
    end)

    safe(function()
        tab:Slider({
            Title = "NPC 增大倍率",
            Min = 1,
            Max = 10,
            Default = NPCSettings.NPCSizeMultiplier,
            Callback = function(v)
                NPCSettings.NPCSizeMultiplier = v
                if NPCSettings.EnableNPCEnlarge then
                    restoreAllNPCs()
                    reEnlargeAllNPCs()
                end
            end
        })
    end)

    safe(function()
        tab:Dropdown({
            Title = "放大部位",
            Multi = false,
            Values = {"头部", "身体", "躯干", "全部"},
            Value = NPCSettings.EnlargePartMode,
            Callback = function(v)
                NPCSettings.EnlargePartMode = v
                restoreAllNPCs()
                if NPCSettings.EnableNPCEnlarge then
                    reEnlargeAllNPCs()
                end
            end
        })
    end)

    safe(function()
        tab:Button({
            Title = "恢复 NPC 正常体型",
            Callback = function()
                NPCSettings.EnableNPCEnlarge = false
                restoreAllNPCs()
            end
        })
    end)
end